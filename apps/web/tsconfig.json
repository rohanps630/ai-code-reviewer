{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Next.js requires these overrides on top of tsconfig.base.json
    "lib": ["dom", "dom.iterable", "ES2023"],
    "jsx": "preserve",
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/db" },
    { "path": "../../packages/agent" }
  ]
}
