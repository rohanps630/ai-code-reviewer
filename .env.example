# ============================================================
# AI Code Reviewer — Environment Variables
# ============================================================
# Copy this file to `.env.local` (web app) and `.env` (indexer).
# Never commit a populated env file. Set spend limits on every
# AI provider console before adding the keys here.
# ============================================================

# ---------- Database (Supabase Postgres + pgvector) ----------
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""   # Server-only. Never expose to client.

# ---------- LLM providers ----------
ANTHROPIC_API_KEY=""           # https://console.anthropic.com — set spend limit FIRST
OPENAI_API_KEY=""              # Fallback + comparison

# ---------- Embeddings & rerank ----------
VOYAGE_API_KEY=""              # https://voyageai.com — voyage-code-3
COHERE_API_KEY=""              # https://cohere.com — rerank-3

# ---------- GitHub (for repo access + webhooks) ----------
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""      # PEM contents, escape newlines as \n
GITHUB_WEBHOOK_SECRET=""

# ---------- Code execution sandbox ----------
E2B_API_KEY=""                 # https://e2b.dev — only if you ship `run_tests` tool

# ---------- Python jobs (Modal) ----------
MODAL_TOKEN_ID=""
MODAL_TOKEN_SECRET=""

# ---------- Observability ----------
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"   # Or your self-hosted URL

SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ---------- Evals ----------
BRAINTRUST_API_KEY=""          # Optional: only if using Braintrust UI

# ---------- Caching ----------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------- App config ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
