{
  "name": "@acr/db",
  "version": "0.0.1",
  "private": true,
  "description": "Drizzle ORM schemas, migrations, and DB client for AI Code Reviewer",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "tsc --build && drizzle-kit generate",
    "migrate": "tsc --build && drizzle-kit migrate",
    "studio": "tsc --build && drizzle-kit studio"
  },
  "dependencies": {
    "@acr/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
