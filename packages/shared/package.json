{
  "name": "@acr/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types and env loader for AI Code Reviewer",
  "type": "module",
  "exports": {
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
