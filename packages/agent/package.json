{
  "name": "@acr/agent",
  "version": "0.0.1",
  "private": true,
  "description": "Agent loop, tools, prompts, and retrieval for AI Code Reviewer (protected paths — see AGENTS.md § 7)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@acr/db": "workspace:*",
    "@acr/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.98.0",
    "@e2b/code-interpreter": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
